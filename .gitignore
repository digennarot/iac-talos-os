# OpenTofu / Terraform state files
tofu/terraform.tfstate
tofu/terraform.tfstate.backup
tofu/.terraform/
tofu/.terraform.lock.hcl
tofu/.terraform.tfstate.*

# OpenTofu plan files
tofu/.tfplan

# Sensitive credential files – never commit these
tofu/credentials.auto.tfvars
tofu/credentails.auto.tfvars
tofu/*.tfvars.json
tofu/*.tfvars.local
tofu/override.tf
tofu/override.tf.json

# Packer: local variable overrides with real credentials
packer/vars/local.pkrvars.hcl
packer/.terraform.lock.hcl

# Talos state and generated secrets
talos/terraform.tfstate
talos/talsecret.sops.*.yaml
talos/clusterconfig/

# Editor artifacts
*.swp
*.swo
*.bak
*~
.tofu_history
.idea/
.vscode/

# ISO images
*.iso
