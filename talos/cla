# ipam.mode=kubernetes
# Use the Kubernetes API (PodCIDR) for IP address management instead of an external IPAM.

# kubeProxyReplacement=true
# Fully replace kube-proxy with Cilium’s eBPF-based proxy for service load balancing.

# securityContext.capabilities.ciliumAgent
# Grant the Cilium agent only the minimal Linux capabilities it needs (e.g., NET_ADMIN, SYS_RESOURCE).

# securityContext.capabilities.cleanCiliumState
# Allow the init container to safely clean up leftover BPF maps with restricted privileges.

# cgroup.autoMount.enabled=false
# Disable Cilium’s cgroup auto-mount since the host (e.g., Talos) already manages cgroupv2.

# cgroup.hostRoot=/sys/fs/cgroup
# Point Cilium at the host’s cgroupv2 root filesystem for proper BPF cgroup integration.

# hubble.enabled=true
# Enable Hubble to collect observability metrics (flows, DNS, HTTP, etc.).

# hubble.relay.enabled=true
# Deploy the Hubble Relay component to aggregate metrics from all nodes.

# hubble.ui.enabled=true
# Install the Hubble UI web frontend for visualizing service maps and flow data.

# hubble.ui.frontend.server.ipv6.enabled=false
# Disable IPv6 socket binding in the UI to avoid “Address family not supported” errors on IPv4-only hosts.

# encryption.enabled=true
# Turn on Cilium’s transparent encryption feature.

# encryption.type=wireguard
# Use WireGuard as the encryption mechanism between endpoints.

